# ═══════════════════════════════════════════
#  OCCUPY MARS — Production Environment
#  Copy to .env.production and fill values
# ═══════════════════════════════════════════

NODE_ENV=production

# ── Database ──
DATABASE_URL=postgresql://user:password@db-host:5432/pixelwar

# ── Server ──
PORT=3000

# ── Auth (REQUIRED — generate with: openssl rand -hex 32) ──
JWT_SECRET=
ADMIN_SECRET=

# ── Blockchain ──
SIGNER_PRIVATE_KEY=0x
TREASURY_ADDRESS=0x

# ── RPC ──
BASE_RPC_URL=https://mainnet.base.org
BNB_RPC_URL=https://bsc-dataseed.binance.org
ETH_RPC_URL=https://eth.llamarpc.com

# ── Contracts ──
BASE_DEPOSIT_ADDRESS=0x
BNB_DEPOSIT_ADDRESS=0x
ETH_DEPOSIT_ADDRESS=0x

# ── Email (SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@occupymars.io

# ── CORS ──
ALLOWED_ORIGINS=https://occupymars.io
